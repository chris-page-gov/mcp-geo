          "BUC"
        ],
        "optional_variants": [
          "BSC",
          "BGG"
        ],
        "variant_detection": {
          "from_title_regex": "\\b(BFC|BFE|BGC|BUC|BSC|BGG)\\b",
          "fallback": "BFC"
        }
      },
      "ingest": {
        "geometry_type": "MULTIPOLYGON",
        "promote_to_multi": true,
        "target_srid": 27700,
        "layer_selection": {
