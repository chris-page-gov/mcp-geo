{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-geo.local/schemas/dsap/event.schema.json",
  "title": "DSAP Canonical Event",
  "type": "object",
  "required": [
    "schemaVersion",
    "eventId",
    "sequence",
    "eventType",
    "conversationId",
    "occurredAt",
    "actor",
    "channel",
    "status",
    "data",
    "correlation",
    "evidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "eventType": {
      "type": "string",
      "enum": [
        "conversation.started",
        "conversation.snapshot_requested",
        "conversation.closed",
        "message.user_visible",
        "message.assistant_visible",
        "message.assistant_conclusion",
        "mcp.session.initialized",
        "mcp.tools.list",
        "mcp.tool.call",
        "mcp.tool.result",
        "mcp.resource.read",
        "mcp.elicitation.requested",
        "mcp.elicitation.responded",
        "ui.choice.made",
        "ui.event.logged",
        "source.http.requested",
        "source.http.responded",
        "decision.assumption_logged",
        "decision.uncertainty_logged",
        "decision.conclusion_recorded",
        "audit_pack.created",
        "audit_pack.sealed",
        "audit_pack.redacted",
        "audit_pack.legal_hold_applied"
      ]
    },
    "conversationId": {
      "type": "string",
      "minLength": 1
    },
    "decisionEpisodeId": {
      "type": [
        "string",
        "null"
      ]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "assistant",
            "client",
            "server",
            "system",
            "ui",
            "source",
            "unknown"
          ]
        },
        "id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "channel": {
      "type": "string",
      "enum": [
        "session_metadata",
        "mcp_stdio",
        "mcp_http",
        "ui_event_log",
        "transcript_visible",
        "source_http"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "observed",
        "error",
        "partial"
      ]
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "data": {
      "type": "object"
    },
    "correlation": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidenceRef"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "file_record"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "recordIndex": {
          "type": "integer",
          "minimum": 0
        },
        "direction": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}

