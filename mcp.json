{
  "$schema": "https://modelcontextprotocol.io/schemas/v1alpha/mcp.json",
  "mcpServers": {
    "mcp-geo-stdio": {
      "command": "./scripts/os-mcp",
      "args": [],
      "env": {
        "OS_API_KEY": "${env:OS_API_KEY}",
        "ONS_LIVE_ENABLED": "${env:ONS_LIVE_ENABLED}"
      },
      "autoApprove": ["tools", "resources"]
    },
    "mcp-geo-docker": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "OS_API_KEY=${env:OS_API_KEY}",
        "-e",
        "ONS_LIVE_ENABLED=true",
        "mcp-geo-server"
      ],
      "autoApprove": ["tools", "resources"]
    },
    "mcp-geo-http": {
      "url": "http://localhost:8000/mcp",
      "autoApprove": ["tools", "resources"]
    }
  }
}
