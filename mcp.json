{
  "$schema": "https://modelcontextprotocol.io/schemas/v1alpha/mcp.json",
  "mcpServers": {
    "mcp-geo-stdio": {
      "command": "python3",
      "args": [
        "scripts/os-mcp"
      ],
      "env": {
        "OS_API_KEY": "${env:OS_API_KEY}",
        "OS_API_KEY_FILE": "${env:OS_API_KEY_FILE}",
        "ONS_LIVE_ENABLED": "${env:ONS_LIVE_ENABLED}",
        "NOMIS_LIVE_ENABLED": "${env:NOMIS_LIVE_ENABLED}",
        "NOMIS_UID": "${env:NOMIS_UID}",
        "NOMIS_SIGNATURE": "${env:NOMIS_SIGNATURE}"
      },
      "autoApprove": ["tools", "resources"]
    },
    "mcp-geo": {
      "command": "python3",
      "args": [
        "scripts/os-mcp"
      ],
      "env": {
        "OS_API_KEY": "${env:OS_API_KEY}",
        "OS_API_KEY_FILE": "${env:OS_API_KEY_FILE}",
        "ONS_LIVE_ENABLED": "${env:ONS_LIVE_ENABLED}",
        "NOMIS_LIVE_ENABLED": "${env:NOMIS_LIVE_ENABLED}",
        "NOMIS_UID": "${env:NOMIS_UID}",
        "NOMIS_SIGNATURE": "${env:NOMIS_SIGNATURE}",
        "MCP_STDIO_UI_SUPPORTED": "1",
        "MCP_STDIO_FRAMING": "line",
        "UI_EVENT_LOG_PATH": "logs/ui-events.jsonl"
      },
      "autoApprove": ["tools", "resources"]
    },
    "mcp-geo-docker": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "OS_API_KEY=${env:OS_API_KEY}",
        "-e",
        "ONS_LIVE_ENABLED=true",
        "mcp-geo-server"
      ],
      "autoApprove": ["tools", "resources"]
    },
    "mcp-geo-http": {
      "url": "http://localhost:8000/mcp",
      "autoApprove": ["tools", "resources"]
    }
  }
}
