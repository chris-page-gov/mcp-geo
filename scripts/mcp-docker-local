#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${MCP_GEO_IMAGE:-mcp-geo-server}"
NETWORK="${MCP_GEO_DOCKER_NETWORK:-mcp-geo}"
POSTGIS_CONTAINER="${MCP_GEO_POSTGIS_CONTAINER:-mcp-geo-postgis}"
POSTGIS_IMAGE="${MCP_GEO_POSTGIS_IMAGE:-mcp-geo-postgis-pgrouting:16-3.4}"
POSTGIS_STORAGE_MODE="${MCP_GEO_POSTGIS_STORAGE_MODE:-volume}"
POSTGIS_VOLUME="${MCP_GEO_POSTGIS_VOLUME:-mcp-geo-postgis}"
DATA_DIR="${MCP_GEO_POSTGIS_DATA_DIR:-$REPO_ROOT/data/postgres}"
LOG_DIR="${MCP_GEO_LOG_DIR:-$REPO_ROOT/logs}"
LANDIS_HOST_DATA_ROOT="${MCP_GEO_LANDIS_DATA_ROOT:-${LANDIS_LOCAL_DATA_ROOT:-$HOME/Data}}"
LANDIS_CONTAINER_DATA_ROOT="${MCP_GEO_LANDIS_CONTAINER_DATA_ROOT:-/landis-data}"
POSTGIS_PUBLISH_PORT="${MCP_GEO_POSTGIS_PUBLISH_PORT:-5432}"
POSTGIS_PGDATA="${MCP_GEO_POSTGIS_PGDATA:-/var/lib/postgresql/data/pgdata}"
POSTGIS_PLATFORM="${MCP_GEO_POSTGIS_PLATFORM:-linux/amd64}"
POSTGIS_DOCKERFILE="${MCP_GEO_POSTGIS_DOCKERFILE:-$REPO_ROOT/.devcontainer/postgis.Dockerfile}"
POSTGIS_BUILD_CONTEXT="${MCP_GEO_POSTGIS_BUILD_CONTEXT:-$REPO_ROOT}"
POSTGIS_BUILD_MODE="${MCP_GEO_POSTGIS_BUILD:-missing}"
POSTGIS_REUSE_DEVCONTAINER="${MCP_GEO_POSTGIS_REUSE_DEVCONTAINER:-auto}"
POSTGIS_REUSE_CONTAINER="${MCP_GEO_POSTGIS_REUSE_CONTAINER:-mcp-geo_devcontainer-postgis-1}"
DOCKER_BIN="${MCP_GEO_DOCKER_BIN:-}"
PYTHON_BIN="${MCP_GEO_PYTHON_BIN:-}"
TRACE_LOG="${MCP_STDIO_TRACE_LOG:-}"
BUILD_MODE="${MCP_GEO_DOCKER_BUILD:-missing}"
DOCKER_UI_EVENT_LOG_PATH="${MCP_GEO_DOCKER_UI_EVENT_LOG_PATH:-${UI_EVENT_LOG_PATH:-/logs/ui-events.jsonl}}"
ROUTE_GRAPH_ENABLED_VALUE="${ROUTE_GRAPH_ENABLED:-true}"
POSTGIS_HOST="${MCP_GEO_POSTGIS_HOST:-postgis}"
POSTGIS_TARGET_CONTAINER="$POSTGIS_CONTAINER"
MANAGE_POSTGIS_CONTAINER=true
PLAN_ONLY="${MCP_GEO_DOCKER_PLAN_ONLY:-0}"
LANDIS_MOUNT_ENABLED=false

log() {
  printf "[mcp-geo] %s\n" "$*" >&2
}

lowercase() {
  printf "%s" "$1" | tr '[:upper:]' '[:lower:]'
}

is_truthy() {
  case "$(lowercase "$1")" in
    1|true|yes|on)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_auto_or_truthy() {
  case "$(lowercase "$1")" in
    auto|1|true|yes|on)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

trim_space() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf "%s" "$value"
}

dotenv_get() {
  local key="$1"
  local file="$2"
  [[ -f "$file" ]] || return 1
  awk -v k="$key" '
    /^[[:space:]]*#/ { next }
    {
      line = $0
      sub(/^[[:space:]]*export[[:space:]]+/, "", line)
      if (line !~ ("^[[:space:]]*" k "[[:space:]]*=")) {
        next
      }
      sub("^[[:space:]]*" k "[[:space:]]*=", "", line)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      if ((line ~ /^".*"$/) || (line ~ /^'\''.*'\''$/)) {
        line = substr(line, 2, length(line) - 2)
      }
      print line
      found = 1
    }
    END {
      if (!found) {
        exit 1
      }
    }
  ' "$file"
}

hydrate_env_secret() {
  local key="$1"
  local file_var="${key}_FILE"
  local value="${!key:-}"
  if [[ -n "$value" ]]; then
    return 0
  fi

  local file_path="${!file_var:-}"
  if [[ -n "$file_path" && -r "$file_path" ]]; then
    value="$(<"$file_path")"
    value="$(trim_space "$value")"
    if [[ -n "$value" ]]; then
      export "$key=$value"
      return 0
    fi
  fi

  if [[ "$(uname -s)" == "Darwin" ]] && command -v launchctl >/dev/null 2>&1; then
    value="$(launchctl getenv "$key" 2>/dev/null || true)"
    value="$(trim_space "$value")"
    if [[ -n "$value" ]]; then
      export "$key=$value"
      return 0
    fi
  fi

  local dotenv_file="${MCP_GEO_ENV_FILE:-$REPO_ROOT/.env}"
  value="$(dotenv_get "$key" "$dotenv_file" 2>/dev/null || true)"
  value="$(trim_space "$value")"
  if [[ -n "$value" ]]; then
    export "$key=$value"
    return 0
  fi
}

wait_for_postgis() {
  local attempt
  for attempt in $(seq 1 30); do
    if "$DOCKER_BIN" exec "$POSTGIS_TARGET_CONTAINER" \
      pg_isready -U mcp_geo -d mcp_geo >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

bootstrap_postgis_sql() {
  local sql_file="$1"
  local label="$2"
  [[ -f "$sql_file" ]] || return 0
  if "$DOCKER_BIN" exec -i "$POSTGIS_TARGET_CONTAINER" \
    psql -v ON_ERROR_STOP=1 -U mcp_geo -d mcp_geo >/dev/null 2>&1 < "$sql_file"; then
    return 0
  fi
  log "$label bootstrap failed; run: docker exec -i $POSTGIS_TARGET_CONTAINER psql -U mcp_geo -d mcp_geo < $sql_file"
  return 1
}

detect_reusable_devcontainer_postgis() {
  local network_name=""
  local mode
  mode="$(lowercase "$POSTGIS_REUSE_DEVCONTAINER")"
  if ! is_auto_or_truthy "$mode"; then
    return 1
  fi
  if ! "$DOCKER_BIN" container inspect "$POSTGIS_REUSE_CONTAINER" >/dev/null 2>&1; then
    if is_truthy "$mode"; then
      log "Configured PostGIS reuse container not found: $POSTGIS_REUSE_CONTAINER"
      exit 1
    fi
    return 1
  fi
  if [[ "$("$DOCKER_BIN" container inspect -f '{{.State.Running}}' "$POSTGIS_REUSE_CONTAINER" 2>/dev/null || true)" != "true" ]]; then
    if is_truthy "$mode"; then
      log "Configured PostGIS reuse container is not running: $POSTGIS_REUSE_CONTAINER"
      exit 1
    fi
    return 1
  fi
  network_name="$("$DOCKER_BIN" container inspect -f '{{range $name, $_ := .NetworkSettings.Networks}}{{println $name}}{{end}}' "$POSTGIS_REUSE_CONTAINER" 2>/dev/null | head -n 1 | tr -d '\r')"
  if [[ -z "$network_name" ]]; then
    if is_truthy "$mode"; then
      log "Unable to discover Docker network for $POSTGIS_REUSE_CONTAINER"
      exit 1
    fi
    return 1
  fi
  NETWORK="$network_name"
  POSTGIS_TARGET_CONTAINER="$POSTGIS_REUSE_CONTAINER"
  MANAGE_POSTGIS_CONTAINER=false
  POSTGIS_HOST="${MCP_GEO_POSTGIS_HOST:-postgis}"
  log "reusing devcontainer PostGIS container: $POSTGIS_TARGET_CONTAINER on network $NETWORK"
  return 0
}

emit_plan() {
  printf 'postgis_target_container=%s\n' "$POSTGIS_TARGET_CONTAINER"
  printf 'postgis_host=%s\n' "$POSTGIS_HOST"
  printf 'manage_postgis_container=%s\n' "$MANAGE_POSTGIS_CONTAINER"
  printf 'network=%s\n' "$NETWORK"
  printf 'postgis_container_name=%s\n' "$POSTGIS_CONTAINER"
  printf 'postgis_image=%s\n' "$POSTGIS_IMAGE"
  printf 'postgis_storage_mode=%s\n' "$POSTGIS_STORAGE_MODE"
  printf 'postgis_volume=%s\n' "$POSTGIS_VOLUME"
  printf 'postgis_reuse_devcontainer=%s\n' "$POSTGIS_REUSE_DEVCONTAINER"
  printf 'landis_host_data_root=%s\n' "$LANDIS_HOST_DATA_ROOT"
  printf 'landis_container_data_root=%s\n' "$LANDIS_CONTAINER_DATA_ROOT"
  printf 'landis_mount_enabled=%s\n' "$LANDIS_MOUNT_ENABLED"
}

ensure_postgis_image() {
  local should_build=false
  case "$POSTGIS_BUILD_MODE" in
    always)
      should_build=true
      ;;
    missing)
      if ! "$DOCKER_BIN" image inspect "$POSTGIS_IMAGE" >/dev/null 2>&1; then
        should_build=true
      fi
      ;;
    never)
      should_build=false
      ;;
    *)
      log "unknown MCP_GEO_POSTGIS_BUILD mode: $POSTGIS_BUILD_MODE (use always|missing|never)"
      exit 1
      ;;
  esac
  if [[ "$should_build" != "true" ]]; then
    return 0
  fi
  if [[ ! -f "$POSTGIS_DOCKERFILE" ]]; then
    log "PostGIS Dockerfile not found: $POSTGIS_DOCKERFILE"
    exit 1
  fi
  log "building PostGIS image: $POSTGIS_IMAGE"
  "$DOCKER_BIN" build \
    --platform "$POSTGIS_PLATFORM" \
    -t "$POSTGIS_IMAGE" \
    -f "$POSTGIS_DOCKERFILE" \
    "$POSTGIS_BUILD_CONTEXT" >&2
}

if [[ -z "$DOCKER_BIN" ]]; then
  for candidate in /usr/local/bin/docker /opt/homebrew/bin/docker /usr/bin/docker; do
    if [[ -x "$candidate" ]]; then
      DOCKER_BIN="$candidate"
      break
    fi
  done
fi
if [[ -z "$DOCKER_BIN" ]] && command -v docker >/dev/null 2>&1; then
  DOCKER_BIN="$(command -v docker)"
fi
if [[ -z "$DOCKER_BIN" || ! -x "$DOCKER_BIN" ]]; then
  log "docker is required but was not found (set MCP_GEO_DOCKER_BIN to its path)."
  exit 1
fi

if ! "$DOCKER_BIN" info >/dev/null 2>&1; then
  log "docker is installed but not running. Start Docker Desktop and retry."
  exit 1
fi

# Hydrate API secrets from host env/secret file/launchctl/.env without requiring
# hardcoded values in host MCP config.
hydrate_env_secret "OS_API_KEY"

case "$POSTGIS_STORAGE_MODE" in
  volume|bind)
    ;;
  *)
    log "invalid MCP_GEO_POSTGIS_STORAGE_MODE: $POSTGIS_STORAGE_MODE (use volume|bind)"
    exit 1
    ;;
esac

if [[ "$POSTGIS_STORAGE_MODE" == "bind" ]]; then
  mkdir -p "$DATA_DIR"
fi
mkdir -p "$LOG_DIR"
if [[ -n "$LANDIS_HOST_DATA_ROOT" && -d "$LANDIS_HOST_DATA_ROOT" ]]; then
  LANDIS_MOUNT_ENABLED=true
fi

detect_reusable_devcontainer_postgis || true

if is_truthy "$PLAN_ONLY"; then
  emit_plan
  exit 0
fi

if [[ "$MANAGE_POSTGIS_CONTAINER" == "true" ]]; then
  ensure_postgis_image
fi

if [[ "$MANAGE_POSTGIS_CONTAINER" == "true" ]] && ! "$DOCKER_BIN" network inspect "$NETWORK" >/dev/null 2>&1; then
  log "creating docker network: $NETWORK"
  "$DOCKER_BIN" network create "$NETWORK" >/dev/null
fi

if [[ "$MANAGE_POSTGIS_CONTAINER" == "true" ]] && "$DOCKER_BIN" container inspect "$POSTGIS_CONTAINER" >/dev/null 2>&1; then
  existing_storage="$("$DOCKER_BIN" container inspect -f '{{range .Mounts}}{{if eq .Destination "/var/lib/postgresql/data"}}{{.Type}}|{{.Name}}|{{.Source}}{{end}}{{end}}' "$POSTGIS_CONTAINER" 2>/dev/null || true)"
  existing_image="$("$DOCKER_BIN" container inspect -f '{{.Config.Image}}' "$POSTGIS_CONTAINER" 2>/dev/null || true)"
  existing_pgdata="$("$DOCKER_BIN" container inspect -f '{{range .Config.Env}}{{println .}}{{end}}' "$POSTGIS_CONTAINER" 2>/dev/null | awk -F= '/^PGDATA=/{print $2}')"
  if [[ "$POSTGIS_STORAGE_MODE" == "volume" && "$existing_storage" == bind* ]]; then
    log "PostGIS container uses bind storage but volume mode is requested."
    log "Recreate with: docker rm -f $POSTGIS_CONTAINER"
  elif [[ "$POSTGIS_STORAGE_MODE" == "bind" && "$existing_storage" == volume* ]]; then
    log "PostGIS container uses volume storage but bind mode is requested."
    log "Recreate with: docker rm -f $POSTGIS_CONTAINER"
  fi
  if [[ -n "$existing_image" && "$existing_image" != "$POSTGIS_IMAGE" ]]; then
    log "PostGIS container image is $existing_image but desired image is $POSTGIS_IMAGE."
    log "Recreate with: docker rm -f $POSTGIS_CONTAINER"
  fi
  if [[ -n "$existing_pgdata" && "$existing_pgdata" != "$POSTGIS_PGDATA" ]]; then
    log "PostGIS container PGDATA is $existing_pgdata but desired PGDATA is $POSTGIS_PGDATA."
    log "Recreate with: docker rm -f $POSTGIS_CONTAINER"
  fi
  if [[ "$("$DOCKER_BIN" container inspect -f '{{.State.Running}}' "$POSTGIS_CONTAINER")" != "true" ]]; then
    log "starting existing PostGIS container: $POSTGIS_CONTAINER"
    "$DOCKER_BIN" start "$POSTGIS_CONTAINER" >/dev/null
  fi
elif [[ "$MANAGE_POSTGIS_CONTAINER" == "true" ]]; then
  log "starting PostGIS container: $POSTGIS_CONTAINER"
  port_args=()
  storage_args=()
  if [[ -n "$POSTGIS_PUBLISH_PORT" && "$POSTGIS_PUBLISH_PORT" != "0" ]]; then
    port_args=(-p "$POSTGIS_PUBLISH_PORT:5432")
  fi
  if [[ "$POSTGIS_STORAGE_MODE" == "bind" ]]; then
    storage_args=(-v "$DATA_DIR:/var/lib/postgresql/data")
    log "PostGIS storage mode: bind ($DATA_DIR)"
  else
    storage_args=(-v "$POSTGIS_VOLUME:/var/lib/postgresql/data")
    log "PostGIS storage mode: volume ($POSTGIS_VOLUME)"
  fi
  "$DOCKER_BIN" run -d --name "$POSTGIS_CONTAINER" --network "$NETWORK" \
    --network-alias postgis \
    -e POSTGRES_DB=mcp_geo \
    -e POSTGRES_USER=mcp_geo \
    -e POSTGRES_PASSWORD=mcp_geo \
    -e PGDATA="$POSTGIS_PGDATA" \
    "${storage_args[@]}" \
    "${port_args[@]}" \
    "$POSTGIS_IMAGE" >/dev/null
fi

if wait_for_postgis; then
  bootstrap_postgis_sql "$REPO_ROOT/scripts/boundary_cache_schema.sql" "boundary cache" || true
  if is_truthy "$ROUTE_GRAPH_ENABLED_VALUE"; then
    bootstrap_postgis_sql "$REPO_ROOT/scripts/route_graph_schema.sql" "route graph" || true
  fi
else
  log "PostGIS did not become ready in time."
fi

should_build=false
case "$BUILD_MODE" in
  always)
    should_build=true
    ;;
  missing)
    if ! "$DOCKER_BIN" image inspect "$IMAGE" >/dev/null 2>&1; then
      should_build=true
    fi
    ;;
  never)
    should_build=false
    ;;
  *)
    log "unknown MCP_GEO_DOCKER_BUILD mode: $BUILD_MODE (use always|missing|never)"
    exit 1
    ;;
esac

if [[ "$should_build" == "true" ]]; then
  log "building image: $IMAGE"
  "$DOCKER_BIN" build -t "$IMAGE" "$REPO_ROOT" >&2
fi

env_args=(
  -e "BOUNDARY_CACHE_ENABLED=true"
  -e "BOUNDARY_CACHE_DSN=postgresql://mcp_geo:mcp_geo@${POSTGIS_HOST}:5432/mcp_geo"
  -e "ROUTE_GRAPH_ENABLED=${ROUTE_GRAPH_ENABLED_VALUE}"
  -e "ROUTE_GRAPH_DSN=postgresql://mcp_geo:mcp_geo@${POSTGIS_HOST}:5432/mcp_geo"
  -e "MCP_GEO_LIVE_DB_DSN=postgresql://mcp_geo:mcp_geo@${POSTGIS_HOST}:5432/mcp_geo"
  -e "LANDIS_WAREHOUSE_DSN=postgresql://mcp_geo:mcp_geo@${POSTGIS_HOST}:5432/mcp_geo"
  -e "MCP_STDIO_FRAMING=${MCP_STDIO_FRAMING:-line}"
  -e "MCP_APPS_RESOURCE_LINK=${MCP_APPS_RESOURCE_LINK:-0}"
  -e "MCP_APPS_CONTENT_MODE=${MCP_APPS_CONTENT_MODE:-embedded}"
  -e "ONS_LIVE_ENABLED=${ONS_LIVE_ENABLED:-true}"
  -e "UI_EVENT_LOG_PATH=${DOCKER_UI_EVENT_LOG_PATH}"
)

if [[ "$LANDIS_MOUNT_ENABLED" == "true" ]]; then
  env_args+=(-e "LANDIS_LOCAL_DATA_ROOT=${LANDIS_CONTAINER_DATA_ROOT}")
fi

for var in \
  OS_API_KEY \
  STDIO_KEY \
  BEARER_TOKENS \
  MCP_STDIO_UI_SUPPORTED \
  MCP_STDIO_CLAUDE_APPS_CONTENT_MODE \
  MCP_TOOLS_DEFAULT_TOOLSET \
  MCP_TOOLS_DEFAULT_INCLUDE_TOOLSETS \
  MCP_TOOLS_DEFAULT_EXCLUDE_TOOLSETS \
  MCP_STDIO_TOOL_CONTENT_MAX_BYTES \
  LANDIS_ENABLED \
  LANDIS_LIVE_ENABLED \
  LANDIS_PORTAL_BASE \
  LANDIS_WAREHOUSE_SCHEMA \
  LANDIS_PRODUCT_REGISTRY_TABLE \
  LANDIS_PROVENANCE_TABLE \
  LANDIS_SOILSCAPES_TABLE \
  LANDIS_PIPE_RISK_TABLE \
  LANDIS_NATMAP_TABLE \
  LANDIS_NATMAP_THEMATIC_TABLE \
  LANDIS_NSI_SITES_TABLE \
  LANDIS_NSI_OBSERVATIONS_TABLE \
  LANDIS_HTTP_TIMEOUT_CONNECT_SECONDS \
  LANDIS_HTTP_TIMEOUT_READ_SECONDS \
  LANDIS_HTTP_RETRIES; do
  value="${!var:-}"
  if [[ -n "$value" ]]; then
    env_args+=(-e "$var=$value")
  fi
done

mount_args=(
  -v "$LOG_DIR:/logs"
)

if [[ "$LANDIS_MOUNT_ENABLED" == "true" ]]; then
  mount_args+=(-v "$LANDIS_HOST_DATA_ROOT:$LANDIS_CONTAINER_DATA_ROOT:ro")
fi

docker_args=(
  run --rm -i
  --network "$NETWORK"
  "${mount_args[@]}"
  "${env_args[@]}"
  "$IMAGE"
)

if [[ -n "$TRACE_LOG" ]]; then
  if [[ -z "$PYTHON_BIN" ]]; then
    for candidate in /usr/bin/python3 /opt/homebrew/bin/python3 /usr/local/bin/python3; do
      if [[ -x "$candidate" ]]; then
        PYTHON_BIN="$candidate"
        break
      fi
    done
  fi
  if [[ -z "$PYTHON_BIN" ]] && command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python3)"
  fi
  if [[ -z "$PYTHON_BIN" || ! -x "$PYTHON_BIN" ]]; then
    log "python3 not found (set MCP_GEO_PYTHON_BIN to override)."
    exit 1
  fi
  exec "$PYTHON_BIN" "$REPO_ROOT/scripts/mcp_stdio_trace_proxy.py" --log "$TRACE_LOG" -- \
    "$DOCKER_BIN" "${docker_args[@]}"
fi

exec "$DOCKER_BIN" "${docker_args[@]}"
