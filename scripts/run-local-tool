#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
MODE="${MCP_GEO_LOCAL_TOOL_MODE:-auto}"
DOCKER_BIN="${MCP_GEO_DOCKER_BIN:-docker}"

usage() {
  cat >&2 <<'EOF'
Usage: scripts/run-local-tool <tool> <uv-package>... -- [tool args...]

Execution order in auto mode:
1. Running repo devcontainer app container
2. Repo-local .venv binary
3. uv run --with ...
4. Tool already on PATH

Override with MCP_GEO_LOCAL_TOOL_MODE=auto|devcontainer|venv|uv|path.
EOF
}

log() {
  printf 'mcp-geo: %s\n' "$*" >&2
}

if [[ $# -lt 2 ]]; then
  usage
  exit 64
fi

TOOL_NAME="$1"
shift

UV_PACKAGES=()
while [[ $# -gt 0 ]]; do
  if [[ "$1" == "--" ]]; then
    shift
    break
  fi
  UV_PACKAGES+=("$1")
  shift
done
TOOL_ARGS=("$@")

venv_tool_path() {
  printf '%s/.venv/bin/%s' "$ROOT_DIR" "$TOOL_NAME"
}

venv_python_path() {
  printf '%s/.venv/bin/python' "$ROOT_DIR"
}

inside_devcontainer() {
  [[ -f "/.dockerenv" && "$ROOT_DIR" == /workspaces/* ]]
}

have_docker() {
  command -v "$DOCKER_BIN" >/dev/null 2>&1
}

devcontainer_app_container() {
  if ! have_docker; then
    return 1
  fi
  if [[ -n "${MCP_GEO_DEVCONTAINER_APP_CONTAINER:-}" ]]; then
    "$DOCKER_BIN" inspect --format '{{.State.Running}}' \
      "$MCP_GEO_DEVCONTAINER_APP_CONTAINER" 2>/dev/null | grep -qx 'true' || return 1
    printf '%s\n' "$MCP_GEO_DEVCONTAINER_APP_CONTAINER"
    return 0
  fi
  "$DOCKER_BIN" ps \
    --filter "label=devcontainer.local_folder=${ROOT_DIR}" \
    --filter 'label=com.docker.compose.service=app' \
    --format '{{.Names}}' | head -n 1
}

devcontainer_workspace_dir() {
  local container="$1"
  local workspace
  workspace="$("$DOCKER_BIN" inspect "$container" --format '{{range .Mounts}}{{if eq .Type "bind"}}{{.Destination}}{{println}}{{end}}{{end}}' | head -n 1)"
  if [[ -n "$workspace" ]]; then
    printf '%s\n' "$workspace"
    return 0
  fi
  return 1
}

devcontainer_tool_cmd() {
  local container="$1"
  local workspace="$2"
  if "$DOCKER_BIN" exec -i -w "$workspace" "$container" test -x ".venv/bin/${TOOL_NAME}" >/dev/null 2>&1; then
    printf '.venv/bin/%s\n' "$TOOL_NAME"
    return 0
  fi
  if "$DOCKER_BIN" exec -i -w "$workspace" "$container" bash -lc "command -v ${TOOL_NAME} >/dev/null 2>&1"; then
    printf '%s\n' "$TOOL_NAME"
    return 0
  fi
  return 1
}

devcontainer_python_cmd() {
  local container="$1"
  local workspace="$2"
  if "$DOCKER_BIN" exec -i -w "$workspace" "$container" test -x ".venv/bin/python" >/dev/null 2>&1; then
    printf '.venv/bin/python\n'
    return 0
  fi
  if "$DOCKER_BIN" exec -i -w "$workspace" "$container" bash -lc "command -v python3 >/dev/null 2>&1"; then
    printf 'python3\n'
    return 0
  fi
  if "$DOCKER_BIN" exec -i -w "$workspace" "$container" bash -lc "command -v python >/dev/null 2>&1"; then
    printf 'python\n'
    return 0
  fi
  return 1
}

runtime_probe_snippet() {
  case "$TOOL_NAME" in
    pytest)
      printf '%s\n' 'import fastapi.testclient, httpx'
      ;;
    mypy)
      printf '%s\n' 'import fastapi, httpx, loguru'
      ;;
    *)
      return 1
      ;;
  esac
}

venv_runtime_ready() {
  local python_cmd snippet
  if ! snippet="$(runtime_probe_snippet)"; then
    return 0
  fi
  python_cmd="$(venv_python_path)"
  if [[ ! -x "$python_cmd" ]]; then
    return 1
  fi
  "$python_cmd" -c "$snippet" >/dev/null 2>&1
}

path_runtime_ready() {
  local python_cmd snippet
  if ! snippet="$(runtime_probe_snippet)"; then
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    python_cmd="python3"
  elif command -v python >/dev/null 2>&1; then
    python_cmd="python"
  else
    return 1
  fi
  "$python_cmd" -c "$snippet" >/dev/null 2>&1
}

devcontainer_runtime_ready() {
  local container="$1"
  local workspace="$2"
  local python_cmd snippet
  if ! snippet="$(runtime_probe_snippet)"; then
    return 0
  fi
  if ! python_cmd="$(devcontainer_python_cmd "$container" "$workspace")"; then
    return 1
  fi
  "$DOCKER_BIN" exec -i -w "$workspace" "$container" \
    "$python_cmd" -c "$snippet" >/dev/null 2>&1
}

run_current_env() {
  local venv_tool
  venv_tool="$(venv_tool_path)"
  if [[ -x "$venv_tool" ]]; then
    if ! venv_runtime_ready; then
      log "$TOOL_NAME found in repo .venv, but the runtime is not ready; trying PATH"
    else
      log "$TOOL_NAME via repo .venv"
      exec "$venv_tool" "${TOOL_ARGS[@]}"
    fi
  fi
  if command -v "$TOOL_NAME" >/dev/null 2>&1; then
    if ! path_runtime_ready; then
      log "$TOOL_NAME found on PATH, but the runtime is not ready"
      exit 127
    fi
    log "$TOOL_NAME via current environment"
    exec "$TOOL_NAME" "${TOOL_ARGS[@]}"
  fi
  log "could not find '$TOOL_NAME' in the current environment"
  exit 127
}

run_devcontainer() {
  local container workspace tool_cmd
  if ! container="$(devcontainer_app_container)"; then
    return 1
  fi
  if [[ -z "$container" ]]; then
    return 1
  fi
  workspace="$(devcontainer_workspace_dir "$container" || true)"
  if [[ -z "$workspace" ]]; then
    workspace="/workspaces/$(basename "$ROOT_DIR")"
  fi
  if ! tool_cmd="$(devcontainer_tool_cmd "$container" "$workspace")"; then
    return 1
  fi
  if ! devcontainer_runtime_ready "$container" "$workspace"; then
    return 1
  fi
  log "$TOOL_NAME via devcontainer (${container})"
  exec "$DOCKER_BIN" exec -i -w "$workspace" "$container" "$tool_cmd" "${TOOL_ARGS[@]}"
}

run_venv() {
  local venv_tool
  venv_tool="$(venv_tool_path)"
  if [[ ! -x "$venv_tool" ]]; then
    return 1
  fi
  if ! venv_runtime_ready; then
    return 1
  fi
  log "$TOOL_NAME via repo .venv"
  exec "$venv_tool" "${TOOL_ARGS[@]}"
}

run_uv() {
  local cmd=()
  local uv_cache_dir
  if ! command -v uv >/dev/null 2>&1; then
    return 1
  fi
  if [[ -z "${UV_CACHE_DIR:-}" ]]; then
    uv_cache_dir="$ROOT_DIR/.cache/uv"
    mkdir -p "$uv_cache_dir"
    export UV_CACHE_DIR="$uv_cache_dir"
  fi
  cmd=(uv run)
  for package in "${UV_PACKAGES[@]}"; do
    cmd+=(--with "$package")
  done
  cmd+=("$TOOL_NAME" "${TOOL_ARGS[@]}")
  log "$TOOL_NAME via uv run"
  exec "${cmd[@]}"
}

run_path_tool() {
  if ! command -v "$TOOL_NAME" >/dev/null 2>&1; then
    return 1
  fi
  if ! path_runtime_ready; then
    return 1
  fi
  log "$TOOL_NAME via PATH"
  exec "$TOOL_NAME" "${TOOL_ARGS[@]}"
}

case "$MODE" in
  auto)
    if inside_devcontainer; then
      run_current_env
    fi
    run_devcontainer || run_venv || run_uv || run_path_tool
    ;;
  devcontainer)
    if inside_devcontainer; then
      run_current_env
    fi
    run_devcontainer
    ;;
  venv)
    run_venv
    ;;
  uv)
    run_uv
    ;;
  path)
    run_path_tool
    ;;
  *)
    log "unknown MCP_GEO_LOCAL_TOOL_MODE '$MODE' (use auto|devcontainer|venv|uv|path)"
    exit 64
    ;;
esac

log "unable to find a runnable backend for '$TOOL_NAME'"
exit 127
