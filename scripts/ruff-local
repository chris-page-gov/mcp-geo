#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

DEFAULT_ARGS=(
  check
  server/mcp/tools.py
  tools/os_mcp.py
  tools/os_peat.py
  tests/test_os_peat.py
  tests/test_psr_peat_e2e.py
  tests/test_evaluation_harness_full.py
  tests/test_os_mcp_route_query.py
)

ARGS=("$@")
if [[ $# -eq 0 ]]; then
  ARGS=("${DEFAULT_ARGS[@]}")
elif [[ "$1" == -* ]]; then
  ARGS=(check "${ARGS[@]}")
else
  case "$1" in
    check|rule|config|linter|clean|format|server|analyze|help|version)
      ;;
    *)
      ARGS=(check "${ARGS[@]}")
      ;;
  esac
fi

exec "$ROOT_DIR/scripts/run-local-tool" ruff ruff -- "${ARGS[@]}"
