#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${MCP_GEO_IMAGE:-mcp-geo-server}"
NETWORK="${MCP_GEO_DOCKER_NETWORK:-mcp-geo}"
POSTGIS_CONTAINER="${MCP_GEO_POSTGIS_CONTAINER:-mcp-geo-postgis}"
POSTGIS_IMAGE="${MCP_GEO_POSTGIS_IMAGE:-postgis/postgis:16-3.4}"
DATA_DIR="${MCP_GEO_POSTGIS_DATA_DIR:-$REPO_ROOT/data/postgres}"
LOG_DIR="${MCP_GEO_LOG_DIR:-$REPO_ROOT/logs}"
POSTGIS_PUBLISH_PORT="${MCP_GEO_POSTGIS_PUBLISH_PORT:-5432}"
DOCKER_BIN="${MCP_GEO_DOCKER_BIN:-}"
PYTHON_BIN="${MCP_GEO_PYTHON_BIN:-}"
TRACE_LOG="${MCP_STDIO_TRACE_LOG:-}"
BUILD_MODE="${MCP_GEO_DOCKER_BUILD:-missing}"

log() {
  printf "[mcp-geo] %s\n" "$*" >&2
}

if [[ -z "$DOCKER_BIN" ]]; then
  for candidate in /usr/local/bin/docker /opt/homebrew/bin/docker /usr/bin/docker; do
    if [[ -x "$candidate" ]]; then
      DOCKER_BIN="$candidate"
      break
    fi
  done
fi
if [[ -z "$DOCKER_BIN" ]] && command -v docker >/dev/null 2>&1; then
  DOCKER_BIN="$(command -v docker)"
fi
if [[ -z "$DOCKER_BIN" || ! -x "$DOCKER_BIN" ]]; then
  log "docker is required but was not found (set MCP_GEO_DOCKER_BIN to its path)."
  exit 1
fi

if ! "$DOCKER_BIN" info >/dev/null 2>&1; then
  log "docker is installed but not running. Start Docker Desktop and retry."
  exit 1
fi

mkdir -p "$DATA_DIR" "$LOG_DIR"

if ! "$DOCKER_BIN" network inspect "$NETWORK" >/dev/null 2>&1; then
  log "creating docker network: $NETWORK"
  "$DOCKER_BIN" network create "$NETWORK" >/dev/null
fi

if "$DOCKER_BIN" inspect "$POSTGIS_CONTAINER" >/dev/null 2>&1; then
  if [[ "$("$DOCKER_BIN" inspect -f '{{.State.Running}}' "$POSTGIS_CONTAINER")" != "true" ]]; then
    log "starting existing PostGIS container: $POSTGIS_CONTAINER"
    "$DOCKER_BIN" start "$POSTGIS_CONTAINER" >/dev/null
  fi
else
  log "starting PostGIS container: $POSTGIS_CONTAINER"
  port_args=()
  if [[ -n "$POSTGIS_PUBLISH_PORT" && "$POSTGIS_PUBLISH_PORT" != "0" ]]; then
    port_args=(-p "$POSTGIS_PUBLISH_PORT:5432")
  fi
  "$DOCKER_BIN" run -d --name "$POSTGIS_CONTAINER" --network "$NETWORK" \
    -e POSTGRES_DB=mcp_geo \
    -e POSTGRES_USER=mcp_geo \
    -e POSTGRES_PASSWORD=mcp_geo \
    -v "$DATA_DIR:/var/lib/postgresql/data" \
    "${port_args[@]}" \
    "$POSTGIS_IMAGE" >/dev/null
fi

should_build=false
case "$BUILD_MODE" in
  always)
    should_build=true
    ;;
  missing)
    if ! "$DOCKER_BIN" image inspect "$IMAGE" >/dev/null 2>&1; then
      should_build=true
    fi
    ;;
  never)
    should_build=false
    ;;
  *)
    log "unknown MCP_GEO_DOCKER_BUILD mode: $BUILD_MODE (use always|missing|never)"
    exit 1
    ;;
esac

if [[ "$should_build" == "true" ]]; then
  log "building image: $IMAGE"
  "$DOCKER_BIN" build -t "$IMAGE" "$REPO_ROOT" >&2
fi

env_args=(
  -e "BOUNDARY_CACHE_ENABLED=true"
  -e "BOUNDARY_CACHE_DSN=postgresql://mcp_geo:mcp_geo@postgis:5432/mcp_geo"
  -e "MCP_STDIO_UI_SUPPORTED=${MCP_STDIO_UI_SUPPORTED:-1}"
  -e "MCP_STDIO_FRAMING=${MCP_STDIO_FRAMING:-line}"
  -e "ONS_LIVE_ENABLED=${ONS_LIVE_ENABLED:-true}"
  -e "UI_EVENT_LOG_PATH=${UI_EVENT_LOG_PATH:-/logs/ui-events.jsonl}"
)

for var in OS_API_KEY ONS_API_KEY STDIO_KEY BEARER_TOKENS; do
  value="${!var:-}"
  if [[ -n "$value" ]]; then
    env_args+=(-e "$var=$value")
  fi
done

docker_args=(
  run --rm -i
  --network "$NETWORK"
  -v "$LOG_DIR:/logs"
  "${env_args[@]}"
  "$IMAGE"
)

if [[ -n "$TRACE_LOG" ]]; then
  if [[ -z "$PYTHON_BIN" ]]; then
    for candidate in /usr/bin/python3 /opt/homebrew/bin/python3 /usr/local/bin/python3; do
      if [[ -x "$candidate" ]]; then
        PYTHON_BIN="$candidate"
        break
      fi
    done
  fi
  if [[ -z "$PYTHON_BIN" ]] && command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python3)"
  fi
  if [[ -z "$PYTHON_BIN" || ! -x "$PYTHON_BIN" ]]; then
    log "python3 not found (set MCP_GEO_PYTHON_BIN to override)."
    exit 1
  fi
  exec "$PYTHON_BIN" "$REPO_ROOT/scripts/mcp_stdio_trace_proxy.py" --log "$TRACE_LOG" -- \
    "$DOCKER_BIN" "${docker_args[@]}"
fi

exec "$DOCKER_BIN" "${docker_args[@]}"
