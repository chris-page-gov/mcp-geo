#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
VALIDATOR_SCRIPT="scripts/validate_owasp_mcp_server.py"
DEFAULT_OUTPUT_DIR="output/owasp-mcp-validation"

if [[ $# -eq 0 ]]; then
  set -- \
    "${VALIDATOR_SCRIPT}" \
    --profile prod-strict \
    --format both \
    --output-dir "${DEFAULT_OUTPUT_DIR}" \
    --fail-on required
else
  set -- "${VALIDATOR_SCRIPT}" "$@"
fi

export MCP_GEO_LOCAL_TOOL_MODE="${MCP_GEO_LOCAL_TOOL_MODE:-uv}"

exec "${ROOT_DIR}/scripts/run-local-tool" \
  python \
  fastapi \
  pydantic \
  pydantic-settings \
  python-dotenv \
  loguru \
  requests \
  httpx \
  -- \
  "$@"
