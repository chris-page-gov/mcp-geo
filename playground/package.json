{
  "name": "mcp-geo-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:full": "playwright test --config playwright.full.config.js",
    "test:live": "PLAYGROUND_LIVE_SMOKE=1 playwright test --config playwright.live.config.js",
    "test:compact": "playwright test --config playwright.compact.config.js",
    "test:compact-matrix": "playwright test --config playwright.compact-matrix.config.js",
    "test:boundary-harness": "playwright test boundary_explorer_host_harness.spec.js",
    "test:boundary-matrix": "playwright test boundary_explorer_option_matrix.spec.js",
    "test:boundary-ui": "playwright test boundary_explorer_host_harness.spec.js boundary_explorer_controls.spec.js boundary_explorer_local_layers.spec.js boundary_explorer_option_matrix.spec.js",
    "test:trials": "playwright test --config playwright.trials.config.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "svelte": "^5.53.10",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "vite": "^7.3.1"
  },
  "overrides": {
    "@hono/node-server": "1.19.11",
    "ajv": "8.18.0",
    "esbuild": "0.27.3",
    "express-rate-limit": "8.3.1",
    "hono": "4.12.7",
    "rollup": "4.59.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
