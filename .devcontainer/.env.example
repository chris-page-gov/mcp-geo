# Local-only devcontainer overrides (copy to `.devcontainer/.env`).
# Use with: docker compose --env-file .devcontainer/.env -f .devcontainer/docker-compose.yml ...
# VS Code Dev Containers users can export the same vars in their host shell.
# Keep this file out of git history; it can contain machine-specific values.

# Use distinct volume names per worktree to isolate state.
# Replace `myworktree` with a suffix unique to this checkout before copying.
MCP_GEO_POSTGIS_VOLUME=mcp-geo-postgis-myworktree
MCP_GEO_RUNTIME_DATA_VOLUME=mcp-geo-runtime-data-myworktree

# Optional: override the repo-built PostGIS+pgRouting image or platform.
# The upstream `postgis/postgis:16-3.4` base is currently amd64-only, so the
# default platform remains `linux/amd64` on Apple Silicon.
# MCP_GEO_POSTGIS_IMAGE=mcp-geo-postgis-pgrouting:16-3.4
# MCP_GEO_POSTGIS_PLATFORM=linux/amd64

# Optional: pin PostGIS host port (default is random free port).
# MCP_GEO_POSTGIS_HOST_PORT=55432

# Optional: enable ngrok inside the devcontainer image for host-tunnel workflows.
# Default is false so TLS-inspected or proxied networks do not fail the build.
# INSTALL_NGROK=false

# Optional: forward proxy settings into Docker builds and running containers.
# Set both upper and lower case variants if your local tooling expects them.
# HTTP_PROXY=http://proxy.example:8080
# HTTPS_PROXY=http://proxy.example:8080
# NO_PROXY=localhost,127.0.0.1,postgis
# http_proxy=http://proxy.example:8080
# https_proxy=http://proxy.example:8080
# no_proxy=localhost,127.0.0.1,postgis

# Optional: add local corporate root CAs for Docker/devcontainer builds.
# Place one or more `.crt` files in `.devcontainer/certs/` before rebuilding.

# Optional: machine-local runtime secrets and API tokens passed into the app
# container by `.devcontainer/docker-compose.yml`.
# OS_API_KEY=
# STDIO_KEY=
# BEARER_TOKENS=
# OPENAI_API_KEY=
