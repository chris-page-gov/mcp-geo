{
  "name": "os-mcp-dev",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspaces/mcp-geo",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",

      // Yarn's legacy Debian APT repo regularly causes devcontainer builds to fail
      // due to key rotations/expiry. This repo uses npm, so keep Yarn off APT.
      "installYarnUsingApt": false
    }
  },
  "mounts": [
    "source=mcp-geo-codex,target=/home/vscode/.codex,type=volume"
  ],
  "forwardPorts": [
    8000,
    5173,
    8899,
    5432
  ],
  "postCreateCommand": "python3 -m pip install --upgrade pip && python3 -m pip install -e . && python3 -m pip install -e '.[dev,test]' && (python3 -m pip install -e '.[boundaries]' || echo 'mcp-geo: optional boundaries extras failed; continuing with core runtime') && (cd playground && npm install --no-audit --no-fund && npx playwright install --with-deps || true)",
  "postStartCommand": "bash ./scripts/devcontainer_post_start.sh",
  "postAttachCommand": "bash ./scripts/devcontainer_mcp_setup.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "docker.docker",
        "openai.chatgpt",
        "ms-vscode.live-server",
        "charliermarsh.ruff",
        "svelte.svelte-vscode"
      ]
    }
  },
  "updateRemoteUserUID": true
}
