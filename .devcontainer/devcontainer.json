{
  "name": "os-mcp-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "containerEnv": {
    "OS_API_KEY": "${localEnv:OS_API_KEY}",
    "STDIO_KEY": "${localEnv:STDIO_KEY}",
    "BEARER_TOKENS": "${localEnv:BEARER_TOKENS}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "PYTHONPATH": "/workspaces/os-mcp"
  },
  "forwardPorts": [8000, 5173],
  "postCreateCommand": "pip install --user -e .[test] && (cd frontend && npm install --no-audit --no-fund || true)",
  "postStartCommand": "pip install --user -e .[test] >/dev/null 2>&1 || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "docker.docker"
      ]
    }
  }
}
