
# Example environment variables for MCP Geo Server
# Not used, the environment of the host has this
# and the container reads it from there
#
# Storage best practice:
# - keep database/data caches outside git worktrees
# - use Docker named volumes for PostGIS PGDATA
# - point cache/log dirs to a host data root (example below)
#
# Example host data root (macOS):
# MCP_GEO_DATA_ROOT=/Users/<you>/Library/Application Support/mcp-geo
# ONS_DATASET_CACHE_DIR=/Users/<you>/Library/Application Support/mcp-geo/cache/ons
# ONS_GEO_CACHE_DIR=/Users/<you>/Library/Application Support/mcp-geo/cache/ons_geo
# OS_DATA_CACHE_DIR=/Users/<you>/Library/Application Support/mcp-geo/cache/os
# UI_EVENT_LOG_PATH=/Users/<you>/Library/Application Support/mcp-geo/logs/ui-events.jsonl
# PLAYGROUND_EVENT_LOG_PATH=/Users/<you>/Library/Application Support/mcp-geo/logs/playground-events.jsonl

# OS_API_KEY=your_os_api_key_here
# OS_API_KEY_FILE=/absolute/path/to/os_api_key.txt
# ONS_LIVE_ENABLED=true
# ONS_SEARCH_LIVE_ENABLED=true
# ONS_SELECT_LIVE_ENABLED=true
# ONS_DATASET_API_BASE=https://api.beta.ons.gov.uk/v1
# ONS_CATALOG_PATH=resources/ons_catalog.json
# NOMIS_LIVE_ENABLED=true
# NOMIS_API_BASE=https://www.nomisweb.co.uk/api/v01
# NOMIS_UID=your_nomis_uid_here
# NOMIS_SIGNATURE=your_nomis_signature_here
# ONS_DATASET_CACHE_ENABLED=true
# ONS_DATASET_CACHE_DIR=data/cache/ons
# ONS_GEO_CACHE_DIR=data/cache/ons_geo
# ONS_GEO_CACHE_DB=ons_geo_cache.sqlite
# ONS_GEO_CACHE_INDEX_PATH=resources/ons_geo_cache_index.json
# ONS_GEO_PRIMARY_DERIVATION=exact
# ADMIN_LOOKUP_LIVE_ENABLED=true
# ADMIN_LOOKUP_ARCGIS_BASE=https://services1.arcgis.com/ESMARspQHYMw9BZ9/ArcGIS/rest/services
# MCP_GEO_LIVE_DB_DSN=postgresql://mcp_geo:mcp_geo@localhost:5432/mcp_geo
# LOG_JSON=false
# MCP_HTTP_AUTH_MODE=off
# MCP_HTTP_AUTH_TOKEN=replace_with_static_bearer_token
# MCP_HTTP_AUTH_TOKEN_FILE=/absolute/path/to/mcp_http_auth_token.txt
# MCP_HTTP_JWT_HS256_SECRET=replace_with_jwt_signing_secret
# MCP_HTTP_JWT_HS256_SECRET_FILE=/absolute/path/to/mcp_http_jwt_hs256_secret.txt
# MCP_HTTP_JWT_ISSUER=
# MCP_HTTP_JWT_AUDIENCE=
# MCP_HTTP_JWT_REQUIRED_SCOPES=
# MCP_HTTP_SESSION_TTL=900
# MCP_HTTP_SESSION_TOOL_CALL_LIMIT=100
# RATE_LIMIT_PER_MIN=207
# RATE_LIMIT_BYPASS=false
# RATE_LIMIT_EXEMPT_PATH_PREFIXES=/maps/vector/vts/tile,/maps/raster/osm,/maps/static/osm
# UI_EVENT_LOG_PATH=logs/ui-events.jsonl
# PLAYGROUND_EVENT_LOG_PATH=logs/playground-events.jsonl
# OPENAI_WIDGET_DOMAIN=example.ngrok.app
# MCP_APPS_RESOURCE_LINK=false
# MCP_APPS_CONTENT_MODE=embedded
# MCP_TOOLS_DEFAULT_TOOLSET=starter
# MCP_TOOLS_DEFAULT_INCLUDE_TOOLSETS=
# MCP_TOOLS_DEFAULT_EXCLUDE_TOOLSETS=
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# OSM_TILE_BASE=https://tile.openstreetmap.org
# OSM_TILE_CACHE_TTL=3600
# OSM_TILE_CACHE_SIZE=512
# OSM_TILE_USER_AGENT=mcp-geo-playground
# OSM_TILE_CONTACT=https://github.com/chris-page-gov/mcp-geo
# OSM_TILE_BASE=https://tile.openstreetmap.org
# OSM_TILE_USER_AGENT=mcp-geo-playground (+https://github.com/chris-page-gov/mcp-geo)
# OSM_TILE_CACHE_DIR=data/cache/osm_tiles
# OSM_TILE_CACHE_TTL=86400
# CIRCUIT_BREAKER_ENABLED=true
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_RESET_SECONDS=30
# CIRCUIT_BREAKER_HALF_OPEN_SUCCESSES=1
# BOUNDARY_CACHE_ENABLED=false
# BOUNDARY_CACHE_DSN=postgresql://mcp_geo:mcp_geo@localhost:5432/mcp_geo
# BOUNDARY_CACHE_SCHEMA=public
# BOUNDARY_CACHE_TABLE=admin_boundaries
# BOUNDARY_DATASET_TABLE=boundary_datasets
# BOUNDARY_CACHE_MAX_AGE_DAYS=180
# BOUNDARY_CACHE_FALLBACK_LIVE=true
# For Docker-backed local runs, keep PostGIS in a named volume and use the
# repo-built PostGIS+pgRouting image so `os_route.*` can bootstrap against the
# same DB. The upstream `postgis/postgis:16-3.4` base is currently amd64-only,
# so the default platform remains `linux/amd64` on Apple Silicon.
# MCP_GEO_POSTGIS_IMAGE=mcp-geo-postgis-pgrouting:16-3.4
# MCP_GEO_POSTGIS_PLATFORM=linux/amd64
# MCP_GEO_POSTGIS_REUSE_DEVCONTAINER=auto
# For benchmark parity, leave reuse on `auto` and verify with:
# ./scripts/check_shared_benchmark_cache.sh
# MCP_GEO_POSTGIS_STORAGE_MODE=volume
# MCP_GEO_POSTGIS_VOLUME=mcp-geo-postgis
ROUTE_GRAPH_ENABLED=true
ROUTE_GRAPH_DSN=postgresql://mcp_geo:mcp_geo@localhost:5432/mcp_geo
# ROUTE_GRAPH_SCHEMA=routing
# ROUTE_GRAPH_RUNTIME_DIR=data/runtime/routing
# ROUTE_GRAPH_PROVENANCE_FILE=os_mrn_downloads.json
# ROUTE_GRAPH_MAX_STOPS=8
# ROUTE_GRAPH_SOFT_AVOID_PENALTY_SECONDS=180
