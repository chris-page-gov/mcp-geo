    {
      "scheme_id": "thematic-official-ons",
      "scheme_name": "Thematic Official ONS Tree",
      "design_intent": "Mirror ONS top-level themes so users can start from familiar official categories.",
      "entry_mode": "browse-first",
      "primary_grouping_keys": [
        "ons_theme",
        "ons_subtheme",
        "dataset_family",
        "geography_level",
        "time_granularity"
      ],
      "tile_generation_rules": [
        "Create top tiles from ONS top-level themes.",
        "Promote frequently used subthemes into second-level tiles.",
        "Attach 'local view available' badge where sub-national geographies exist.",
        "Prefer dataset cards over bulletin pages."
      ],
      "strengths": [
        "High trust and recognisability for UK users.",
        "Low training burden for analysts already using ONS.",
        "Simple governance and provenance traceability."
      ],
      "weaknesses": [
        "Ambiguous for cross-theme questions (e.g., cost of living + wages + housing).",
        "Can hide best dataset if user does not know domain jargon.",
        "Not optimal for novice question-to-dataset selection."
      ],
      "best_for_personas": [
        "policy_analyst",
        "statistician",
        "returning_ons_user"
      ],
      "minimum_required_metadata": [
        "dataset_id",
        "title",
        "summary",
        "ons_theme",
        "ons_subtheme",
        "geography_coverage",
        "time_coverage",
