{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-geo.local/schemas/ons_datapack_schema.json",
  "title": "MCP Geo DataPack Schema",
  "description": "Schema for tile-to-card-to-graph statistical dataset selection (ONS scope B) in MCP Geo.",
  "type": "object",
  "required": [
    "datapack_id",
    "version",
    "created_at_utc",
    "tile",
    "data_card",
    "primary_dataset",
    "related_datasets",
    "link_edges",
    "chart_templates",
    "ai_safe_controls"
  ],
  "properties": {
    "datapack_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "tile": {
      "type": "object",
      "required": [
        "tile_id",
        "tile_label",
        "intent_tags",
        "elicitation_questions"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "tile_label": {
          "type": "string"
        },
        "intent_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "persona_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "elicitation_questions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "data_card": {
      "type": "object",
      "required": [
        "card_id",
        "headline",
        "summary",
        "why_this_dataset",
        "why_not_others",
        "geography_coverage",
        "time_coverage",
        "release_frequency",
        "revision_status",
        "accessibility_notes"
      ],
      "properties": {
        "card_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "headline": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "why_this_dataset": {
          "type": "string"
        },
        "why_not_others": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "geography_coverage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "time_coverage": {
          "type": "object",
          "required": [
            "start_period",
            "end_period",
            "frequency"
          ],
          "properties": {
            "start_period": {
              "type": "string"
            },
            "end_period": {
              "type": "string"
            },
            "frequency": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "release_frequency": {
          "type": "string"
        },
        "revision_status": {
          "type": "string",
          "enum": [
            "provisional",
            "revised",
            "final",
            "mixed"
          ]
        },
        "accessibility_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "primary_dataset": {
      "$ref": "#/$defs/dataset_object"
    },
    "related_datasets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dataset_object"
      },
      "minItems": 1
    },
    "link_edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link_edge"
      }
    },
    "chart_templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "chart_id",
          "chart_type",
          "purpose",
          "x_field",
          "y_field",
          "accessibility_notes"
        ],
        "properties": {
          "chart_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "chart_type": {
            "type": "string",
            "enum": [
              "line",
              "bar",
              "map",
              "scatter",
              "table",
              "index-line"
            ]
          },
          "purpose": {
            "type": "string"
          },
          "x_field": {
            "type": "string"
          },
          "y_field": {
            "type": "string"
          },
          "secondary_field": {
            "type": "string"
          },
          "accessibility_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "ai_safe_controls": {
      "type": "object",
      "required": [
        "misuse_risk_level",
        "required_caveat_display",
        "must_check_comparability",
        "must_show_release_date",
        "must_show_revision_status",
        "disallow_unqualified_ranking",
        "prompt_guardrails"
      ],
      "properties": {
        "misuse_risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "required_caveat_display": {
          "type": "boolean"
        },
        "must_check_comparability": {
          "type": "boolean"
        },
        "must_show_release_date": {
          "type": "boolean"
        },
        "must_show_revision_status": {
          "type": "boolean"
        },
        "disallow_unqualified_ranking": {
          "type": "boolean"
        },
        "prompt_guardrails": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": [
        "source_name",
        "source_url",
        "retrieved_at",
        "licence",
        "method_note",
        "quality_note"
      ],
      "properties": {
        "source_name": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "licence": {
          "type": "string"
        },
        "method_note": {
          "type": "string"
        },
        "quality_note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "dataset_object": {
      "type": "object",
      "required": [
        "dataset_id",
        "dataset_title",
        "dataset_url",
        "provider",
        "dataset_family",
        "geography_levels",
        "time_granularity",
        "latest_release_date",
        "fitness_for_use_score",
        "confidence",
        "explainability_note",
        "known_limitations",
        "comparability_warnings",
        "provenance"
      ],
      "properties": {
        "dataset_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "dataset_title": {
          "type": "string"
        },
        "dataset_url": {
          "type": "string",
          "format": "uri"
        },
        "provider": {
          "type": "string"
        },
        "dataset_family": {
          "type": "string"
        },
        "geography_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "time_granularity": {
          "type": "string",
          "enum": [
            "annual",
            "quarterly",
            "monthly",
            "weekly",
            "daily",
            "mixed"
          ]
        },
        "latest_release_date": {
          "type": "string",
          "format": "date"
        },
        "fitness_for_use_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "explainability_note": {
          "type": "string"
        },
        "known_limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "comparability_warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "additionalProperties": false
    },
    "link_edge": {
      "type": "object",
      "required": [
        "edge_id",
        "from_dataset_id",
        "to_dataset_id",
        "link_type",
        "link_reason",
        "provenance"
      ],
      "properties": {
        "edge_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "from_dataset_id": {
          "type": "string"
        },
        "to_dataset_id": {
          "type": "string"
        },
        "link_type": {
          "type": "string",
          "enum": [
            "same_measure_different_geography",
            "same_measure_different_time_granularity",
            "derived_from",
            "complementary_context",
            "quality_or_revision_context",
            "methodological_dependency",
            "leading_or_lagging_indicator"
          ]
        },
        "link_reason": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
